# ================================================================
# LeadLayer OS — Environment Variables
# ================================================================

# ── Supabase ─────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=

# ── App ───────────────────────────────────────────────────────────
APP_BASE_URL=

# ── Anthropic / Claude ────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Email (Resend) ────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# ── Encryption ────────────────────────────────────────────────────
ENCRYPTION_KEY=

# ── DataForSEO ────────────────────────────────────────────────────
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# ── Firecrawl ─────────────────────────────────────────────────────
FIRECRAWL_API_KEY=

# ── WordPress.com OAuth ───────────────────────────────────────────
# For wordpress.com-hosted sites. Self-hosted uses Application Passwords instead.
# Add production domain to Redirect URLs at: https://developer.wordpress.com/apps/140075/
WPCOM_CLIENT_ID=
WPCOM_CLIENT_SECRET=

# ── Background jobs ───────────────────────────────────────────────
ANALYZER_JOB_SECRET=
