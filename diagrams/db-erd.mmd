    tenants {
      uuid id PK
      text name
      geo_code geo
      vertical_code vertical
    }
    memberships {
      uuid user_id FK
      uuid tenant_id FK
      app_role role
    }
    site_connections {
      uuid id PK
      uuid tenant_id FK
      connection_type type
      connection_status status
    }
    tenant_secrets {
      uuid id PK
      uuid tenant_id FK
      text key
      bytea ciphertext
      int version
    }
