    tenants  ||--o{ master_plans : has
    master_plans ||--o{ monthly_plans : has
    tenants  ||--o{ pages : has
    pages    ||--o{ page_snapshots : has
    monthly_plans ||--o{ change_groups : has
    change_groups ||--o{ changes : has
    changes  ||--o{ wp_write_operations : produces
    tenants  ||--o{ scans : has
