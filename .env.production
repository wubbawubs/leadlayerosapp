# Public client-side env — safe to commit.
# These are the Supabase *publishable* (anon-equivalent) values that ship in
# every browser bundle and are protected by Row Level Security. They are NOT
# secrets. Committing them lets any build (Lovable publish, CI, etc.) bake the
# client Supabase config in, since the real .env is gitignored.
#
# Secrets (SUPABASE_SERVICE_ROLE_KEY, RESEND_API_KEY, ANTHROPIC_API_KEY, …)
# live only in the gitignored .env and in the Cloudflare Worker secrets —
# never here, never VITE_-prefixed, never in the client bundle.
VITE_SUPABASE_URL="https://frovpuhucsnbnjieqlnn.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_8V_QWqOgc0P1vj9-EwjKzQ_o81bMwKP"
VITE_SUPABASE_PROJECT_ID="frovpuhucsnbnjieqlnn"
